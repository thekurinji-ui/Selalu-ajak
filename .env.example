# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/selalu_ajak"
DIRECT_URL="postgresql://user:password@localhost:5432/selalu_ajak"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google Sign-In (BAB 7.5) — opsional
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# WhatsApp Blast (BAB 13) — via Fonnte (https://fonnte.com), WhatsApp gateway
# non-resmi. Ambil token dari Fonnte Dashboard -> Device -> lihat Token.
WHATSAPP_API_URL="https://api.fonnte.com/send"
WHATSAPP_API_TOKEN=""
# Opsional — kalau diisi, endpoint /api/whatsapp/webhook akan menolak request
# yang tidak menyertakan ?secret= yang sama persis. Daftarkan URL webhook di
# Fonnte -> Device -> Edit -> Webhook URL:
#   https://<domain-anda>/api/whatsapp/webhook?secret=<isi-sama-dengan-ini>
WHATSAPP_WEBHOOK_SECRET=""

# Object storage untuk media (foto, musik, QRIS) — Cloudflare R2, S3-compatible.
# Dipakai src/lib/r2.ts: upload foto sendiri di Invitation Builder (BAB 10.7)
# & thumbnail/preview template di Admin Console.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Payment Gateway (BAB 18) — Midtrans Snap.
# MIDTRANS_IS_PRODUCTION wajib disamakan dengan jenis key yang diisi: "true"
# kalau key Production, "false"/kosong kalau masih key Sandbox (prefix SB-).
MIDTRANS_SERVER_KEY=""
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# Email transaksional (BAB 19.5 & 20.8) — Resend (https://resend.com).
# Opsional: kalau kosong, fitur Lupa Password tetap bisa dites (link reset
# tampil langsung di halaman, mode development), lihat src/lib/email.ts.
RESEND_API_KEY=""
EMAIL_FROM="Selalu Ajak <noreply@selaluajak.kurinji.asia>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DOMAIN="selaluajak.kurinji.asia"
# Base URL Selalu Ajak sendiri, dipakai untuk header X-Override-Notification
# ke Midtrans (lihat catatan "multi-web Kurinji" di README). WAJIB diisi di
# Production, kalau tidak invoice tidak akan pernah otomatis jadi PAID.
APP_URL="http://localhost:3000"
